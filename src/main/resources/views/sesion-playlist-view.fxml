<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="musicgo.controllers.SesionPlaylistViewController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Sesión y Playlists" style="-fx-font-size: 18px;"/>

    <HBox spacing="10.0">
        <TextField fx:id="aliasLoginField" promptText="Alias"/>
        <Button text="Iniciar sesión" onAction="#onIniciarSesion"/>
        <Label fx:id="usuarioActivoLabel" text="(sin sesión)"/>
    </HBox>

    <Label text="Tus playlists"/>
    <ListView fx:id="playlistsListView" prefHeight="120.0"/>
    <HBox spacing="10.0">
        <TextField fx:id="nombrePlaylistField" promptText="Nombre de la nueva playlist"/>
        <Button text="Crear playlist" onAction="#onCrearPlaylist"/>
    </HBox>

    <Label text="Catálogo (selecciona un audio para agregarlo a la playlist seleccionada arriba)"/>
    <ListView fx:id="catalogoListView" prefHeight="150.0"/>
    <Button text="Agregar audio a playlist seleccionada" onAction="#onAgregarAudio"/>

    <Button text="Cerrar sesión y salir" onAction="#onSalir"/>
</VBox>
