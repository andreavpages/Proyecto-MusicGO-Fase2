<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="musicgo.controllers.SesionPlaylistViewController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
    </padding>

    <Label text="Sesión y Playlists" styleClass="titulo-app"/>

    <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="card">
        <TextField fx:id="aliasLoginField" promptText="Alias" HBox.hgrow="ALWAYS"/>
        <Button text="Iniciar sesión" onAction="#onIniciarSesion"/>
        <Label fx:id="usuarioActivoLabel" text="(sin sesión)" styleClass="estado-sesion"/>
    </HBox>

    <HBox spacing="18.0" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
            <Label text="Tus playlists" styleClass="titulo-seccion"/>
            <ListView fx:id="playlistsListView" prefHeight="220.0" VBox.vgrow="ALWAYS"/>
            <HBox spacing="10.0">
                <TextField fx:id="nombrePlaylistField" promptText="Nueva playlist" HBox.hgrow="ALWAYS"/>
                <Button text="Crear" onAction="#onCrearPlaylist"/>
            </HBox>
        </VBox>

        <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
            <Label text="Catálogo" styleClass="titulo-seccion"/>
            <ListView fx:id="catalogoListView" prefHeight="220.0" VBox.vgrow="ALWAYS"/>
            <Button text="Agregar a playlist seleccionada" onAction="#onAgregarAudio" maxWidth="Infinity"/>
        </VBox>
    </HBox>

    <Button text="Cerrar sesión y salir" onAction="#onSalir" styleClass="button-secundario"/>
</VBox>
