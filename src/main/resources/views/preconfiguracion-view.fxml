<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="musicgo.controllers.PreConfiguracionViewController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Pre Configuración" style="-fx-font-size: 18px;"/>

    <Label text="Registrar usuario"/>
    <HBox spacing="10.0">
        <TextField fx:id="aliasField" promptText="Alias"/>
        <TextField fx:id="nombreField" promptText="Nombre"/>
        <Button text="Registrar" onAction="#onRegistrarUsuario"/>
    </HBox>

    <Label text="Catálogo"/>
    <ListView fx:id="catalogoListView" prefHeight="150.0"/>

    <Label text="Agregar audio (bono)"/>
    <HBox spacing="10.0">
        <ComboBox fx:id="tipoComboBox" promptText="Tipo"/>
        <TextField fx:id="tituloField" promptText="Título"/>
        <TextField fx:id="clasificacionField" promptText="Clasificación"/>
        <TextField fx:id="duracionField" promptText="Duración (segundos)"/>
    </HBox>
    <HBox spacing="10.0">
        <TextField fx:id="campo3Field" promptText="Artista / Anfitrión"/>
        <TextField fx:id="campo4Field" promptText="Álbum / Descripción"/>
        <Button text="Agregar audio" onAction="#onAgregarAudio"/>
    </HBox>

    <HBox spacing="10.0">
        <Button fx:id="continuarButton" text="Continuar" onAction="#onContinuar" disable="true"/>
        <Button text="Salir" onAction="#onSalir"/>
    </HBox>
</VBox>
